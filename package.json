{
  "name": "clawon",
  "version": "0.1.11",
  "description": "Backup and restore your OpenClaw workspace",
  "type": "module",
  "bin": {
    "clawon": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts"
  },
  "keywords": [
    "openclaw",
    "clawon",
    "backup",
    "restore",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "tar": "^7.5.10"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
